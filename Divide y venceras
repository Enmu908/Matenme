def max_min(arr, inicio, fin):

    if inicio == fin:
        return arr[inicio], arr[inicio]

    if fin == inicio + 1:
        if arr[inicio] < arr[fin]:
            return arr[inicio], arr[fin]
        else:
            return arr[fin], arr[inicio]

    medio = (inicio + fin) // 2

    min1, max1 = max_min(arr, inicio, medio)
    min2, max2 = max_min(arr, medio + 1, fin)

    return min(min1,min2), max(max1,max2)


arr = [5,3,9,1,7]
print(max_min(arr,0,len(arr)-1))

