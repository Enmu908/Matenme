def suma_arreglo(arr, inicio, fin):
    if inicio == fin:
        return arr[inicio]

    medio = (inicio + fin) // 2

    izquierda = suma_arreglo(arr, inicio, medio)
    derecha = suma_arreglo(arr, medio + 1, fin)

    return izquierda + derecha


