def buscar_matriz(matriz, x):

    filas = len(matriz)
    columnas = len(matriz[0])

    i = 0
    j = columnas - 1

    while i < filas and j >= 0:

        if matriz[i][j] == x:
            return True

        elif matriz[i][j] > x:
            j -= 1

        else:
            i += 1

    return False


