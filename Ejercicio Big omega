#include <iostream>
#include <sstream>
using namespace std;
/*=============================
  ESTRUCTURA PERSONA
=============================*/
struct Persona {
    string nombre;
    int edad;
};
/*=============================
  BACKEND
  - Procesa datos sucios
  - Construye personas válidas
  - Ordena por nombre
=============================*/
void backend(string datos) {
    Persona personas[20];
    int total = 0;
    string token;
    string nombreAnterior = "";
    stringstream ss(datos);
    // Separar por comas
    while (getline(ss, token, ',')) {
        // Quitar espacio inicial si existe
        if (token.length() > 0 && token[0] == ' ')
            token.erase(0,1);
        // Si el token empieza con número → es edad
        if (token.length() > 0 && isdigit(token[0])) {
            int edad = stoi(token);
            // Validar edad razonable
            if (edad > 0 && edad < 120 && nombreAnterior != "") {
                personas[total].nombre = nombreAnterior;
                personas[total].edad = edad;
                total++;
            }
            nombreAnterior = "";
        }
        else {
            // Es texto → posible nombre
            nombreAnterior = token;
        }
    }
    // Ordenamiento Bubble Sort por nombre
    for (int i = 0; i < total - 1; i++) {
        for (int j = 0; j < total - i - 1; j++) {
            if (personas[j].nombre > personas[j + 1].nombre) {
                Persona aux = personas[j];
                personas[j] = personas[j + 1];
                personas[j + 1] = aux;
            }
        }
    }
    cout << "\n========== DATOS ORDENADOS (BACKEND) ==========\n\n";
    for (int i = 0; i < total; i++) {
        cout << personas[i].nombre << " - "
             << personas[i].edad << endl;
    }
}
/*=============================
  FRONTEND
  - Simula archivo TXT sucio
  - Envía datos al backend
=============================*/
int main() {
    string archivoTXT =
        "Jose, pedro, 294, memo, pepita, 28, "
        "ana, 25, carlos, 19, sofia, 31";
    cout << "========== DATOS RECIBIDOS (FRONTEND) ==========\n\n";
    cout << archivoTXT << endl;
    backend(archivoTXT);
    return 0;
}
