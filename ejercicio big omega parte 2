<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<title>Ordenador de Archivos TXT</title>

<style>

body{
background:#0f172a;
font-family:Arial;
color:white;
margin:0;
text-align:center;
}

h1{
margin-top:40px;
font-size:40px;
}

.container{
width:900px;
margin:auto;
margin-top:30px;
}

.controls{
margin-top:20px;
margin-bottom:20px;
}

button{
padding:10px 20px;
background:#22c55e;
border:none;
color:white;
font-weight:bold;
cursor:pointer;
}

button:hover{
background:#16a34a;
}

input{
padding:6px;
}

.info{
margin-top:10px;
font-size:14px;
color:#cbd5f5;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
background:#1e293b;
}

th{
background:#3b82f6;
padding:12px;
}

td{
padding:10px;
border-bottom:1px solid #334155;
}

tr:hover{
background:#334155;
}

</style>

</head>

<body>

<h1>ORDENADOR DE ARCHIVOS TXT</h1>

<div class="container">

<div class="controls">

<form action="/procesar" method="post" enctype="multipart/form-data">

<input type="file" name="archivo" required>

<button type="submit">Procesar Archivo</button>

</form>

<div class="info">
Complejidad del algoritmo (Big Omega): Ω(n log n)
</div>

</div>

<table>

<tr>
<th>ID</th>
<th>Nombre</th>
<th>Apellido</th>
<th>Edad</th>
<th>Correo</th>
</tr>

{% if personas %}

{% for persona in personas %}

<tr>
<td>{{persona.id}}</td>
<td>{{persona.nombre}}</td>
<td>{{persona.apellido}}</td>
<td>{{persona.edad}}</td>
<td>{{persona.correo}}</td>
</tr>

{% endfor %}

{% else %}

<tr><td>-</td><td>-</td><td>-</td><td>-</td><td>-</td></tr>
<tr><td>-</td><td>-</td><td>-</td><td>-</td><td>-</td></tr>
<tr><td>-</td><td>-</td><td>-</td><td>-</td><td>-</td></tr>

{% endif %}

</table>

</div>

</body>

</html>
